# =============================================================================
# Communicare — environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values for local development.
# For the GitHub Pages deploy, set these as repo secrets so the build workflow
# can bake them into the static export.
#
# All client-visible Supabase vars use the NEXT_PUBLIC_ prefix — they're safe
# to expose, since RLS protects the actual data.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project URL — looks like https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable anon key — safe to expose; RLS does the row-level security
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic (Node-only, for the self-hosted server/generate-homepage.ts) --
# Not needed for the static GH Pages build. Required only when you're hosting
# the Next.js app on a Node runtime (Vercel, Lovable, Cloudflare Workers,
# Fly.io) and using the in-app API route instead of the Supabase Edge Function.
ANTHROPIC_API_KEY=

# --- Mapbox ------------------------------------------------------------------
# Required for the discovery map at /find. Safe to expose (it's a public token);
# scope it to your domain in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- ElevenLabs (for the Remotion video subproject) --------------------------
# Used by `remotion/scripts/generate-audio.ts` to produce the music bed and
# voiceover. Only needed when you want to (re)generate the video soundtrack.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Optional: override the static-export base path -------------------------
# When deploying to GitHub Pages as a project page (e.g. github.io/communicare),
# the deploy workflow sets BASE_PATH=/communicare automatically. Leave unset
# for local dev or custom-domain deploys.
# BASE_PATH=/communicare

# =============================================================================
# Supabase Edge Function secrets — NOT read at build time. Set these with:
#   supabase secrets set KEY=value
# They live only on the function runtime.
# =============================================================================

# --- Perplexity (for /find ZIP search) ---------------------------------------
# Powers find-nearby-farms. Get one at https://www.perplexity.ai/settings/api
# Uses the sonar-pro model — pricing is per-call, see Perplexity dashboard.
# PERPLEXITY_API_KEY=pplx-...

# --- Mapbox (server-side geocoding, used inside find-nearby-farms) -----------
# Distinct from NEXT_PUBLIC_MAPBOX_TOKEN — this one is used by the edge
# function to forward-geocode ZIPs and unresolved farm addresses. Can be the
# same token, but scoping a separate restricted token is cleaner.
# MAPBOX_TOKEN=pk....

# --- Resend (for record-farm-inquiry's outbound emails) ----------------------
# Optional. When set, inquiries land in the farm's inbox via Resend and the
# one-time "a neighbor found you" outreach email fires on first contact.
# When unset, the function returns a mailto: handoff and the client opens
# the member's own email client.
# RESEND_API_KEY=re_...
# RESEND_FROM=hello@communicare.farm

# --- Public site URL (for absolute links in outbound emails) -----------------
# Used by record-farm-inquiry to build the /claim?slug=... URL in the
# outreach email. Defaults to https://communicare.farm.
# PUBLIC_SITE_URL=https://communicare.farm
