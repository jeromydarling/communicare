{
  "name": "communicare",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p functions/tsconfig.json --noEmit",
    "deploy": "next build && wrangler deploy",
    "deploy:dry": "next build && wrangler deploy --dry-run",
    "cf:provision": "bash scripts/cf-provision.sh",
    "cf:status": "curl -fsS https://mycommuni.care/api/_health | jq .",
    "d1:migrate": "wrangler d1 migrations apply communicare-db --remote",
    "d1:migrate:local": "wrangler d1 migrations apply communicare-db --local",
    "pg-to-d1": "node --experimental-strip-types scripts/migrate-pg-to-d1.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^8.0.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.106.1",
    "mapbox-gl": "^3.24.0",
    "next": "^15.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260603.1",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.60.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "wrangler": "^4.97.0"
  }
}
