// =============================================================================
// Wrangler config — the spine of the Cloudflare migration
// =============================================================================
// This file declares every Cloudflare binding the project will use across
// D1, R2, KV, Workers AI, and Pages Functions. Resources don't exist yet
// at the time this lands — IDs are filled in by `wrangler` commands or
// the CF dashboard. Placeholder `<TODO>` values get replaced as each
// resource is provisioned.
//
// The full migration plan is in docs/CLOUDFLARE_MIGRATION.md. This file is
// the shape it lands in — every binding the app eventually depends on is
// declared up front so PRs that wire each piece can drop in without a
// config change.
//
// Layout:
//   - Static site lives in `out/` (Next.js `output: "export"`).
//   - Pages Functions live in `functions/` (auto-detected, auto-deployed
//     by CF Pages on push).
//   - Standalone Workers (for jobs that don't belong on the Pages path)
//     will live in `cloudflare/workers/<name>/` with their own
//     wrangler config inheriting from this one.
//   - D1 schema migrations live in `cloudflare/d1/migrations/`.
// =============================================================================
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "communicare",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],

  // Pages: the build output Cloudflare Pages serves directly.
  "pages_build_output_dir": "out",

  // D1 — the primary database. Replaces Supabase Postgres.
  // Run `wrangler d1 create communicare-db`, then paste the database_id.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "communicare-db",
      "database_id": "<TODO: wrangler d1 create>",
      "migrations_dir": "cloudflare/d1/migrations"
    }
  ],

  // KV — caching + sessions + rate-limit buckets.
  // Run `wrangler kv:namespace create CACHE`, etc., for each, then paste IDs.
  "kv_namespaces": [
    { "binding": "CACHE", "id": "<TODO>" },
    { "binding": "SESSIONS", "id": "<TODO>" },
    { "binding": "RATELIMIT", "id": "<TODO>" }
  ],

  // R2 — farm photos, product photos, and audit CSVs from the import flow.
  "r2_buckets": [
    { "binding": "FARM_PHOTOS", "bucket_name": "communicare-farm-photos" },
    { "binding": "PRODUCT_PHOTOS", "bucket_name": "communicare-product-photos" },
    { "binding": "IMPORTS", "bucket_name": "communicare-imports" }
  ],

  // Workers AI — alt-text generation, embeddings, low-stakes drafts.
  // High-stakes generation (homepage drafter, CSV column mapping) stays
  // on Anthropic Claude; see docs/CLOUDFLARE_MIGRATION.md Phase 7.
  "ai": {
    "binding": "AI"
  },

  // Vectorize — vector store for the embeddings the AI binding generates.
  // Used for semantic search across farm descriptions, share notes, etc.
  // Create with:
  //   wrangler vectorize create communicare-embeddings \
  //     --dimensions=384 --metric=cosine
  // Then paste the index_name in here if you customized it.
  "vectorize": [
    {
      "binding": "EMBEDDINGS",
      "index_name": "communicare-embeddings"
    }
  ],

  // Vars baked into Workers at deploy time. Secrets (API keys, etc.)
  // are set via `wrangler secret put ...` and never live in this file.
  "vars": {
    "SITE_URL": "https://mycommuni.care",
    "ENVIRONMENT": "production"
  },

  // Observability — turn on Workers logs.
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1.0
  }
}
